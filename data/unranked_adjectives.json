    "kana": "",
    "pitch": null,
    "pos": "イ形容詞",
    "adj_type": "i",
    "level": [],
    "gloss_cn": "动词（简体形式）／形容词（简体形式）／名词＋だけあって\\n二类形容词－な＋だけあって",
    "gloss_en": ""
  },
